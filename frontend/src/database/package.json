{
  "name": "prosbc-nap-database",
  "version": "1.0.0",
  "description": "Enhanced database system for ProSBC NAP Testing project",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "db:init": "node scripts/init-database.js",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "db:backup": "node scripts/backup.js",
    "db:restore": "node scripts/restore.js",
    "db:cleanup": "node scripts/cleanup.js",
    "db:health": "node scripts/health-check.js",
    "test:db": "jest --testPathPattern=database",
    "lint:db": "eslint src/database/**/*.js"
  },
  "dependencies": {
    "mongoose": "^8.0.0",
    "crypto": "^1.0.1",
    "fs": "^0.0.1-security",
    "path": "^0.12.7"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "eslint": "^8.0.0",
    "@jest/globals": "^29.0.0",
    "supertest": "^6.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/prosbc-nap-testing"
  },
  "keywords": [
    "prosbc",
    "nap",
    "database",
    "mongodb",
    "file-management",
    "audit-trail",
    "validation"
  ],
  "author": "ProSBC Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "mongodb": "^6.0.0"
  }
}
